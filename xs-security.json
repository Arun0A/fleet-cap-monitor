{
  "xsappname": "o2c-app",
  "tenant-mode": "dedicated",
  "scopes": [
    { "name": "$XSAPPNAME.Device.manage", "description": "Manage devices (register/update)" },
    { "name": "$XSAPPNAME.Telemetry.ingest", "description": "Ingest telemetry from devices" },
    { "name": "$XSAPPNAME.WorkOrder.manage", "description": "Manage work orders" }
  ],
  "role-templates": [
    {
      "name": "DeviceManager",
      "description": "Can register and manage devices",
      "scope-references": [ "$XSAPPNAME.Device.manage" ]
    },
    {
      "name": "Technician",
      "description": "Can view and update assigned work orders",
      "scope-references": [ "$XSAPPNAME.WorkOrder.manage" ]
    },
    {
      "name": "Ops",
      "description": "Can ingest telemetry and manage work orders",
      "scope-references": [ "$XSAPPNAME.Telemetry.ingest", "$XSAPPNAME.WorkOrder.manage" ]
    }
  ]
}
