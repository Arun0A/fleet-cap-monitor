{
  "name": "fleet-cap-project",
  "version": "1.0.0",
  "description": "Fleet monitoring SAP CAP application — KIIT Capstone Project",
  "main": "srv/o2c-service.js",
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "build": "cds build",
    "test": "jest --runInBand --forceExit --testTimeout=30000",
    "deploy": "cds deploy --to sqlite:dev.db && cds-serve"
  },
  "dependencies": {
    "@sap/cds": "^7",
    "express": "^4"
  },
  "devDependencies": {
    "@sap/cds-dk": "^7",
    "axios": "^1.15.1",
    "jest": "^29",
    "sqlite3": "^5",
    "supertest": "^6"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "./dev.db"
        }
      }
    },
    "[test]": {
      "requires": {
        "db": {
          "kind": "sqlite",
          "credentials": {
            "url": ":memory:"
          }
        }
      }
    },
    "features": {
      "assert_integrity": "DB"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
