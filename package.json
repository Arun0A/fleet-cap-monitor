{
  "name": "o2c-cap-project",
  "version": "1.0.0",
  "description": "Order-to-Cash (O2C) SAP CAP Application — KIIT Capstone Project",
  "main": "srv/o2c-service.js",
  "scripts": {
    "start":   "cds-serve",
    "watch":   "cds watch",
    "build":   "cds build",
    "test":    "jest --testTimeout=30000",
    "deploy":  "cds deploy --to sqlite:./dev.db && cds-serve"
  },
  "dependencies": {
    "@sap/cds":     "^7",
    "express":      "^4"
  },
  "devDependencies": {
    "@sap/cds-dk":  "^7",
    "jest":         "^29",
    "supertest":    "^6",
    "sqlite3":      "^5"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout":     30000
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "sqlite:./dev.db"
        }
      }
    },
    "features": {
      "assert_integrity": "DB"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
